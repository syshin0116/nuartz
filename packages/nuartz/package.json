{
  "name": "nuartz",
  "version": "0.1.5",
  "description": "Publish your Obsidian vault as a Next.js website — wikilinks, backlinks, graph view, search",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/syshin0116/nuartz.git"
  },
  "keywords": ["markdown", "obsidian", "nextjs", "blog", "mdx", "remark", "rehype", "digital-garden", "wikilink", "obsidian-publish", "quartz", "tailwindcss", "shadcn", "knowledge-base", "second-brain"],
  "homepage": "https://github.com/syshin0116/nuartz#readme",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist", "styles"],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./styles.css": "./styles/prose.css"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "hast-util-to-html": "^9.0.0",
    "rehype-autolink-headings": "^7.0.0",
    "rehype-katex": "^7.0.0",
    "rehype-pretty-code": "^0.14.3",
    "rehype-raw": "^7.0.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.0",
    "remark-breaks": "^4.0.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.0",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.0.0",
    "shiki": "^4.0.1",
    "unified": "^11.0.0",
    "unist-util-visit": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@vitest/coverage-v8": "^4.0.18",
    "typescript": "^5",
    "vitest": "^4.0.18"
  }
}
